{
  "scopeName": "source.chip8",
  "name": "CHIP-8",
  "fileTypes": ["asm", "chip8", "ch8"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#directives" },
    { "include": "#instructions" },
    { "include": "#registers" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#labels" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "match": ";.*$", "name": "comment.line.semicolon.chip8" },
        { "match": "#[^$0-9].*$", "name": "comment.line.hash.chip8" }
      ]
    },
    "directives": {
      "match": "\\.(org|byte|word|ascii|asciz|align|space|const)\\b",
      "name": "keyword.directive.chip8"
    },
    "instructions": {
      "match": "\\b(CLS|RET|SYS|JP|CALL|SE|SNE|LD|ADD|OR|AND|XOR|SUB|SUBN|SHR|SHL|RND|DRW|SKP|SKNP)\\b",
      "name": "keyword.instruction.chip8"
    },
    "registers": {
      "match": "\\b(V[0-9A-F]|I|DT|ST|K|F|B)\\b",
      "name": "variable.other.register.chip8"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.chip8"
    },
    "numbers": {
      "patterns": [
        { "match": "#?0x[0-9a-fA-F]+", "name": "constant.numeric.hex.chip8" },
        { "match": "#?\\$[0-9a-fA-F]+", "name": "constant.numeric.hex.chip8" },
        { "match": "\\b[0-9]+\\b", "name": "constant.numeric.decimal.chip8" }
      ]
    },
    "labels": {
      "match": "^[a-zA-Z_][a-zA-Z0-9_]*:",
      "name": "entity.name.function.label.chip8"
    }
  }
}
